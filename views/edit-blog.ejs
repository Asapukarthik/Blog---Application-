<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <title>Blogify | Edit Blog</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container mt-5 mb-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="auth-card p-4 p-md-5 bg-white rounded-4 shadow-sm border">
            <div class="mb-4 d-flex align-items-center justify-content-between">
              <div class="text-center text-md-start">
                <h2 class="fw-800 text-main mb-2">Edit Your Story</h2>
                <p class="text-muted m-0">Refine your thoughts and update your masterpiece.</p>
              </div>
              <a href="/blog/<%= blog._id %>" class="text-muted text-decoration-none small d-flex align-items-center gap-2 hover-opacity">
                <i class="fa-solid fa-arrow-left"></i>
                <span>Back</span>
              </a>
            </div>

            <form action="/blog/edit/<%= blog._id %>" method="POST" enctype="multipart/form-data">
              <div class="mb-4 text-center">
                <label class="form-label fw-600 d-block mb-3">Current Cover Image</label>
                <% if (blog.coverImageURL) { %>
                  <img src="<%= blog.coverImageURL %>" class="rounded-3 shadow-sm mb-3" style="max-height: 200px; width: auto; object-fit: cover;" alt="Current Cover">
                <% } %>
                <div class="p-3 border rounded-3 bg-light">
                  <label for="coverImage" class="form-label small text-muted mb-2">Upload New Image (optional)</label>
                  <input
                    type="file"
                    class="form-control form-control-sm"
                    id="coverImage"
                    name="coverImage"
                  />
                </div>
              </div>

              <div class="mb-4">
                <label for="title" class="form-label fw-600">Blog Title</label>
                <input
                  type="text"
                  class="form-control form-control-lg border-0 bg-light"
                  id="title"
                  name="title"
                  required
                />
              </div>

              <div class="mb-4">
                <label for="tags" class="form-label fw-600">Tags</label>
                <input
                  type="text"
                  class="form-control border-0 bg-light"
                  id="tags"
                  name="tags"
                  value="<%= blog.tags.join(', ') %>"
                  placeholder="Technology, Life, Travel (comma separated)"
                />
              </div>

              <div class="mb-4">
                <label for="body" class="form-label fw-600">Blog Content</label>
                <div id="editor" style="height: 300px;" class="bg-light rounded-3 border-0">
                  <%- blog.body %>
                </div>
                <input type="hidden" name="body" id="body-input">
              </div>

              <div class="d-grid gap-2 mt-5">
                <button class="btn btn-primary btn-lg rounded-pill py-3" type="submit">
                  Update Article
                </button>
                <a href="/blog/<%= blog._id %>" class="btn btn-link text-muted text-decoration-none">Discard Changes</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <%- include('./partials/scripts') %>
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
      var quill = new Quill('#editor', {
        theme: 'snow',
        placeholder: 'Refine your masterpiece...',
        modules: {
          toolbar: [
            [{ 'header': [1, 2, 3, false] }],
            ['bold', 'italic', 'underline', 'strike'],
            ['blockquote', 'code-block'],
            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
            ['link', 'clean']
          ]
        }
      });

      var form = document.querySelector('form');
      form.onsubmit = function() {
        var body = document.querySelector('#body-input');
        body.value = quill.root.innerHTML;
      };
    </script>
  </body>
</html>
