<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <title>Blogify | Add New Blog</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container mt-5 mb-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="auth-card p-4 p-md-5 bg-white rounded-4 shadow-sm border">
            <div class="mb-4 d-flex align-items-center justify-content-between">
              <div>
                <h2 class="fw-800 text-main mb-2">Compose Your Story</h2>
                <p class="text-muted m-0">Share your thoughts and insights with the world.</p>
              </div>
              <a href="/" class="text-muted text-decoration-none small d-flex align-items-center gap-2 hover-opacity">
                <i class="fa-solid fa-arrow-left"></i>
                <span>Back</span>
              </a>
            </div>

            <form action="/blog" method="post" enctype="multipart/form-data">
              <div class="mb-4">
                <label for="title" class="form-label fw-600">Blog Title</label>
                <input
                  type="text"
                  class="form-control form-control-lg border-0 bg-light"
                  id="title"
                  name="title"
                  placeholder="A catchy title for your post"
                  required
                />
              </div>

              <div class="mb-4">
                <label for="tags" class="form-label fw-600">Tags</label>
                <input
                  type="text"
                  class="form-control border-0 bg-light"
                  id="tags"
                  name="tags"
                  placeholder="Technology, Life, Travel (comma separated)"
                />
              </div>
              
              <div class="mb-4">
                <label for="coverImage" class="form-label fw-600">Cover Image</label>
                <div class="p-4 border border-2 border-dashed rounded-3 text-center bg-light">
                  <input
                    type="file"
                    class="form-control"
                    id="coverImage"
                    name="coverImage"
                    required
                  />
                  <small class="text-muted d-block mt-2">Recommended size: 1200x630px</small>
                </div>
              </div>

              <div class="mb-4">
                <label for="body" class="form-label fw-600">Blog Content</label>
                <div id="editor" style="height: 300px;" class="bg-light rounded-3 border-0"></div>
                <input type="hidden" name="body" id="body-input">
              </div>

              <div class="d-grid gap-2 mt-5">
                <button class="btn btn-primary btn-lg rounded-pill py-3" type="submit">
                  Publish Article
                </button>
                <a href="/" class="btn btn-link text-muted text-decoration-none">Cancel</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <%- include('./partials/scripts') %>
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
      var quill = new Quill('#editor', {
        theme: 'snow',
        placeholder: 'Start writing your masterpiece here...',
        modules: {
          toolbar: [
            [{ 'header': [1, 2, 3, false] }],
            ['bold', 'italic', 'underline', 'strike'],
            ['blockquote', 'code-block'],
            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
            ['link', 'clean']
          ]
        }
      });

      var form = document.querySelector('form');
      form.onsubmit = function() {
        var body = document.querySelector('#body-input');
        body.value = quill.root.innerHTML;
      };
    </script>
  </body>
</html>
