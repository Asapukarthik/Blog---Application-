<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Blogify | Create Account</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container pb-5">
      <div class="auth-container">
        <div class="auth-card">
          <div class="auth-header">
            <h2 class="text-main">Create Account</h2>
            <p class="text-muted">Join our community of writers and readers</p>
          </div>

          <form action="/user/signup" method="post">
            <div class="mb-4">
              <label for="fullName" class="form-label fw-600">Full Name</label>
              <div class="input-group">
                <span class="input-group-text bg-light border-0"><i class="fa-solid fa-user text-muted"></i></span>
                <input
                  type="text"
                  class="form-control"
                  id="fullName"
                  name="fullName"
                  placeholder="John Doe"
                  required
                />
              </div>
            </div>
            <div class="mb-4">
              <label for="email" class="form-label fw-600">Email Address</label>
              <div class="input-group">
                <span class="input-group-text bg-light border-0"><i class="fa-solid fa-envelope text-muted"></i></span>
                <input
                  type="email"
                  name="email"
                  class="form-control"
                  id="email"
                  placeholder="name@example.com"
                  required
                />
              </div>
            </div>
            <div class="mb-4">
              <label for="password" class="form-label fw-600">Password</label>
              <div class="input-group">
                <span class="input-group-text bg-light border-0"><i class="fa-solid fa-lock text-muted"></i></span>
                <input
                  name="password"
                  type="password"
                  class="form-control"
                  id="password"
                  placeholder="••••••••"
                  required
                />
              </div>
            </div>
            <div class="d-grid mt-5">
              <button type="submit" class="btn btn-primary py-3">Sign Up</button>
            </div>
            <div class="text-center mt-4">
              <p class="text-muted small">Already have an account? <a href="/user/signin" class="text-primary fw-700 text-decoration-none">Sign In</a></p>
            </div>
          </form>
        </div>
      </div>
    </div>

    <%- include('./partials/scripts') %>
  </body>
</html>
