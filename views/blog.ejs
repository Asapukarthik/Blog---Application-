<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title><%= blog.title %> | Blogify</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container mt-5">
      <div class="row justify-content-center">
        <div class="col-lg-10">
          <!-- Back Navigation -->
          <div class="mb-4">
            <a href="/" class="text-muted text-decoration-none small d-inline-flex align-items-center gap-2 hover-opacity">
              <i class="fa-solid fa-arrow-left"></i>
              <span>Back to Feed</span>
            </a>
          </div>

          <!-- Hero Section -->
          <div class="blog-hero mb-4">
            <% if (blog.coverImageURL) { %>
              <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>" />
            <% } %>
          </div>

          <!-- Blog Header -->
          <div class="mb-5">
            <h1 class="display-4 fw-800 mb-3"><%= blog.title %></h1>
            
            <div class="mb-4">
              <% if (blog.tags && blog.tags.length > 0) { %>
                <% blog.tags.forEach(tag => { %>
                  <span class="badge rounded-pill bg-light text-primary border border-primary-subtle me-1"><%= tag %></span>
                <% }) %>
              <% } %>
            </div>

            <div class="d-flex align-items-center justify-content-between">
              <div class="d-flex align-items-center">
                <% if (blog.createdBy) { %>
                  <img src="<%= blog.createdBy.profileImageURL %>" width="48" height="48" class="rounded-circle me-3" alt="Author" />
                  <div>
                    <h6 class="mb-0 fw-700 text-main"><%= blog.createdBy.fullName %></h6>
                    <small class="text-muted"><%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></small>
                  </div>
                <% } %>
              </div>

              <% if (user && (user._id.toString() === blog.createdBy._id.toString() || user.role === 'admin')) { %>
                <div class="d-flex gap-2">
                  <a href="/blog/edit/<%= blog._id %>" class="btn btn-outline-primary btn-sm rounded-pill px-3">Edit</a>
                  <form action="/blog/delete/<%= blog._id %>" method="POST" onsubmit="return confirm('Delete this post?');">
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">Delete</button>
                  </form>
                </div>
              <% } %>
            </div>

            <div class="mt-4 p-3 bg-light rounded-4 d-flex justify-content-between align-items-center">
              <div class="d-flex gap-4">
                <span class="text-muted small"><i class="fa-regular fa-eye"></i> <%= blog.views %> views</span>
                <form action="/blog/like/<%= blog._id %>" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-link p-0 text-decoration-none text-muted small">
                    <i class="<%= (user && blog.likes.includes(user._id)) ? 'fa-solid fa-heart text-danger' : 'fa-regular fa-heart' %>"></i> <%= blog.likes.length %> likes
                  </button>
                </form>
              </div>
              <div class="d-flex gap-2 align-items-center">
                <span class="text-muted small me-2">Share:</span>
                <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent(locals.currentUrl || '') %>" target="_blank" class="btn btn-sm btn-light border rounded-circle"><i class="fa-brands fa-linkedin-in"></i></a>
                <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(locals.currentUrl || '') %>" target="_blank" class="btn btn-sm btn-light border rounded-circle"><i class="fa-brands fa-x-twitter"></i></a>
              </div>
            </div>
          </div>

          <!-- Blog Body -->
          <div class="blog-content mb-5">
            <%- blog.body %>
          </div>

          <!-- Comments Section -->
          <section class="comment-section">
            <h3 class="fw-800 mb-4">Discussions (<%= comments.length %>)</h3>
            
            <% if (locals.user) { %>
              <div class="auth-card p-4 bg-white rounded-4 border mb-5">
                <form action="/blog/comment/<%= blog._id %>" method="POST">
                  <div class="mb-3">
                    <label class="form-label fw-600">Join the conversation</label>
                    <textarea name="content" class="form-control" rows="3" placeholder="What are your thoughts?" required></textarea>
                  </div>
                  <button class="btn btn-primary px-4" type="submit">Post Comment</button>
                </form>
              </div>
            <% } else { %>
              <div class="alert alert-light border rounded-4 text-center py-4 mb-5">
                <p class="mb-2">Want to join the discussion?</p>
                <a href="/user/signin" class="btn btn-primary btn-sm px-4">Sign In to Comment</a>
              </div>
            <% } %>

            <div class="comments-list">
              <% comments.forEach(comment => { %>
                <div class="comment-card shadow-sm">
                  <div class="d-flex align-items-center mb-3">
                    <img src="<%= comment.createdBy.profileImageURL %>" width="40" height="40" class="rounded-circle me-3 border" alt="Avatar" />
                    <div>
                      <h6 class="mb-0 fw-700 text-main"><%= comment.createdBy.fullName %></h6>
                      <small class="text-muted"><%= new Date(comment.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></small>
                    </div>
                  </div>
                  <div class="ps-md-5">
                    <p class="mb-0 text-muted"><%= comment.content %></p>
                  </div>
                </div>
              <% }) %>
            </div>
          </section>
        </div>
      </div>
    </div>

    <%- include('./partials/scripts') %>
  </body>
</html>
