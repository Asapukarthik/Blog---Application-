<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Blogify | Profile</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container mt-5">
      <div class="row justify-content-center">
        <div class="col-md-6">
          <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="card-header bg-primary text-white py-4 position-relative">
              <a href="/" class="text-white text-decoration-none small position-absolute start-0 ms-4 h-100 d-flex align-items-center hover-opacity">
                <i class="fa-solid fa-arrow-left me-2"></i>
                <span class="d-none d-sm-inline">Back</span>
              </a>
              <h3 class="mb-0 text-center">User Profile</h3>
            </div>
            <div class="card-body p-5">
              <div class="text-center mb-4">
                <img 
                  src="<%= user.profileImageURL %>" 
                  alt="<%= user.fullName %>" 
                  class="rounded-circle border border-4 border-primary-subtle shadow-sm" 
                  style="width: 150px; height: 150px; object-fit: cover;"
                >
              </div>

              <form action="/user/profile/update" method="POST" enctype="multipart/form-data">
                <div class="mb-4">
                  <label for="fullName" class="form-label fw-bold">Full Name</label>
                  <input 
                    type="text" 
                    name="fullName" 
                    id="fullName" 
                    class="form-control form-control-lg rounded-3" 
                    value="<%= user.fullName %>" 
                    required
                  >
                </div>

                <div class="mb-4">
                  <label for="profileImage" class="form-label fw-bold">Update Profile Image</label>
                  <input 
                    type="file" 
                    name="profileImage" 
                    id="profileImage" 
                    class="form-control rounded-3"
                  >
                  <div class="form-text mt-2">Recommended: Square image (JPG, PNG)</div>
                </div>

                <div class="d-grid gap-2 mt-5">
                  <button type="submit" class="btn btn-primary btn-lg rounded-3">Update Profile</button>
                  <a href="/" class="btn btn-outline-secondary btn-lg rounded-3">Back to Home</a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('./partials/scripts') %>
  </body>
</html>
