<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container">
    <a class="navbar-brand d-flex align-items-center gap-2" href="/">
      <i class="fa-solid fa-feather-pointed"></i>
      <span>Blogify</span>
    </a>
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavDropdown"
      aria-controls="navbarNavDropdown"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavDropdown">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
        <li class="nav-item">
          <a class="nav-link" aria-current="page" href="/"><i class="fa-solid fa-house me-2"></i>Home</a>
        </li>
        <li class="nav-item">
          <button id="theme-toggle" class="nav-link border-0 bg-transparent">
            <i class="fa-solid fa-moon d-inline-block theme-icon-dark"></i>
            <i class="fa-solid fa-sun d-none theme-icon-light"></i>
          </button>
        </li>
        <% if (locals.user) { %>
        <li class="nav-item">
          <a class="nav-link" href="/blog/add-new"><i class="fa-solid fa-pen-to-square me-2"></i>Write</a>
        </li>
        <li class="nav-item dropdown ms-lg-3">
          <a
            class="nav-link dropdown-toggle d-flex align-items-center gap-2"
            href="#"
            role="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
          >
            <img 
              src="<%= user.profileImageURL %>" 
              width="35" 
              height="35" 
              class="rounded-circle border border-2 border-primary-subtle" 
              alt="Avatar"
              onerror="this.src='/images/default.png'"
            >
            <span class="user-name d-none d-md-block"><%= user.fullName %></span>
          </a>
          <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2">
            <li><a class="dropdown-item py-2" href="/user/profile"><i class="fa-solid fa-user me-2 text-muted"></i>My Profile</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item py-2 text-danger" href="/user/logout"><i class="fa-solid fa-right-from-bracket me-2"></i>Logout</a></li>
          </ul>
        </li>
        <% } else { %>
        <li class="nav-item">
          <a class="nav-link" href="/user/signup">Get Started</a>
        </li>
        <li class="nav-item ms-lg-3">
          <a class="btn btn-primary px-4 py-2" href="/user/signin">Login</a>
        </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<% if (locals.error) { %>
<div class="container mt-4">
  <div class="alert alert-danger shadow-sm" role="alert"><%= locals.error %></div>
</div>
<% } %>
