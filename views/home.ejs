<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Blogify | Home</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container mt-5">
      <!-- Premium Hero Section -->
      <div class="hero-section">
        <h1 class="hero-title">Unleash Your Stories.</h1>
        <p class="hero-subtitle">Step into a world where your ideas meet a global audience. The most insightful community of writers and readers is waiting for you.</p>
        <% if (!locals.user) { %>
          <div class="d-flex gap-3 justify-content-center">
            <a href="/user/signup" class="btn btn-primary btn-lg px-5">Join the Community</a>
            <a href="/user/signin" class="btn btn-outline-secondary btn-lg px-5">Sign In</a>
          </div>
        <% } %>
      </div>

      <div class="row align-items-center mb-5">
        <div class="col-md-6">
          <h2 class="fw-800 m-0">Latest Stories</h2>
          <p class="text-muted">Discover the newest insights and stories from our community.</p>
        </div>
        <div class="col-md-6">
          <form action="/" method="GET" class="d-flex gap-2">
            <input 
              type="text" 
              name="search" 
              class="form-control" 
              placeholder="Search blogs by title..." 
              value="<%= locals.searchQuery || '' %>"
            >
            <button type="submit" class="btn btn-primary px-4">Search</button>
          </form>
        </div>
      </div>

      <div class="mb-5 d-flex gap-2 align-items-center flex-wrap">
        <span class="text-muted small fw-600 me-2">Trending Tags:</span>
        <% if (locals.trendingTags && trendingTags.length > 0) { %>
          <% trendingTags.forEach(tag => { %>
            <a href="/?search=<%= tag %>" class="btn btn-sm btn-light border rounded-pill px-3"><%= tag %></a>
          <% }) %>
        <% } else { %>
          <span class="text-muted small italic">No tags yet...</span>
        <% } %>
      </div>

      <div class="row g-4">
        <% blogs.forEach(blog => { %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="blog-card">
            <% if (blog.coverImageURL) { %>
              <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>" />
            <% } else { %>
              <img src="/images/default.png" alt="Default Cover" />
            <% } %>
            <div class="blog-card-body">
              <h3 class="blog-title"><%= blog.title %></h3>
              <div class="mb-3">
                <% if (blog.tags && blog.tags.length > 0) { %>
                  <% blog.tags.forEach(tag => { %>
                    <span class="badge rounded-pill bg-light text-primary border border-primary-subtle me-1"><%= tag %></span>
                  <% }) %>
                <% } %>
              </div>
              <p class="text-muted text-truncate mb-4">Discover the story behind the title...</p>
              <div class="d-flex justify-content-between align-items-center">
                <a href="/blog/<%= blog._id %>" class="btn btn-primary btn-sm px-4">Read Article</a>
                <div class="text-muted small">
                  <span class="me-2"><i class="fa-regular fa-eye"></i> <%= blog.views || 0 %></span>
                  <span class="me-2"><i class="fa-regular fa-heart"></i> <%= blog.likes ? blog.likes.length : 0 %></span>
                  <span><%= blog.readingTime %> min read</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <%- include('./partials/scripts') %>
  </body>
</html>
